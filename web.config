<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- DELETE/PUT metodlarını bloklayan WebDAV-ı söndür -->
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
    </handlers>

    <!-- Next.js localhost:3000-ə proxy et -->
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" preserveQueryString="true" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>
</configuration>
